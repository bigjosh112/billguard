# MongoDB Atlas connection string
# Get from: Atlas dashboard → Connect → Drivers → Copy connection string
# Replace <password> with your database user password
MONGODB_URI=mongodb+srv://billguard:<password>@billguard-cluster.xxxxx.mongodb.net/billguard?retryWrites=true&w=majority

# Google Gemini API key (free)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Server port (leave as 8000 for local development)
PORT=8000

# Environment
ENVIRONMENT=development
